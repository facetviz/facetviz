{
  "name": "facetviz",
  "version": "0.1.8",
  "description": "A modular TypeScript SVG charting library with a declarative config API, small-multiples trellising, and a wide range of chart types.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./series/*": {
      "types": "./dist/entries/series/*.d.ts",
      "import": "./dist/entries/series/*.js",
      "default": "./dist/entries/series/*.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./src/index.ts",
    "./src/series/register-all.ts",
    "./src/entries/series/*.ts",
    "./dist/index.js",
    "./dist/series/register-all.js",
    "./dist/entries/series/*.js"
  ],
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:typecheck": "tsc -p test/visual/tsconfig.json",
    "test:visual:update": "playwright test --update-snapshots",
    "test:performance": "playwright test -c playwright.performance.config.ts",
    "test:performance:typecheck": "tsc -p test/performance/tsconfig.json",
    "test:modular": "node scripts/check-modular-bundles.mjs",
    "test:bundle-size": "npm run build:site && node scripts/check-bundle-size.mjs && npm run test:modular",
    "test:all": "npm run test && npm run test:visual:typecheck && npm run test:performance:typecheck && npm run test:bundle-size && npm run test:visual && npm run test:performance",
    "build:site": "esbuild src/index.ts --bundle --format=esm --minify-syntax --outfile=docs/lib/facetviz.js"
  },
  "keywords": [
    "chart",
    "svg",
    "typescript",
    "visualization"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.21.5",
    "happy-dom": "^15.11.7",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
