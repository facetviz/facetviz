{
  "name": "jchart",
  "version": "0.1.0",
  "description": "A modular TypeScript SVG charting library with a Highcharts-like API, small-multiples (Tableau-style) trellising, and a wide range of chart types.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["chart", "svg", "typescript", "visualization", "highcharts", "tableau"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
