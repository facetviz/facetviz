{
  "name": "facetviz",
  "version": "0.1.0",
  "description": "A modular TypeScript SVG charting library with a declarative config API, small-multiples trellising, and a wide range of chart types.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:site": "esbuild src/index.ts --bundle --format=esm --outfile=docs/lib/facetviz.js"
  },
  "keywords": [
    "chart",
    "svg",
    "typescript",
    "visualization"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.21.5",
    "happy-dom": "^15.11.7",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
